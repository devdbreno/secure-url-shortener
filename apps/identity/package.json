{
  "name": "@secure-url-shortener/identity",
  "version": "1.0.0",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write src/**/*.ts",
    "test": "jest --passWithNoTests --runInBand",
    "test:cov": "yarn test --coverage",
    "test:e2e": "yarn test --config jest-e2e.json",
    "test:unit": "yarn test --no-cache --config jest-unit.json",
    "test:unit:watch": "yarn test --no-cache --config jest-unit.json --watch"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "yarn lint",
      "yarn format",
      "yarn build"
    ]
  },
  "engines": {
    "yarn": ">=4.9.1",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.18",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/source-map-support": "^0.5.10",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "ts",
      "json"
    ],
    "rootDir": "src",
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "testPathIgnorePatterns": [
      "<rootDir>/main.ts",
      "<rootDir>/presentation/app.module.ts"
    ],
    "testMatch": [
      "**/?(*.)+(e2e-spec|spec-unit).ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.module.ts",
      "!<rootDir>/main.ts",
      "!<rootDir>/presentation/app.module.ts"
    ],
    "coveragePathIgnorePatterns": [
      ".mock.ts$",
      ".module.ts$",
      "<rootDir>/main.ts",
      "<rootDir>/presentation/app.module.ts"
    ],
    "moduleNameMapper": {
      "@infra/(.*)$": "<rootDir>/infra/$1",
      "@domain/(.*)$": "<rootDir>/domain/$1",
      "@application/(.*)$": "<rootDir>/application/$1",
      "@presentation/(.*)$": "<rootDir>/presentation/$1"
    }
  }
}
