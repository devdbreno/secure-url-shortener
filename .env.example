# Common environment variables
NODE_ENV=development
JWT_SECRET=change_me_for_local_development
JWT_EXPIRATION=1h

# API configuration
PORT_IDENTITY=4000
PORT_SHORT_URL=4001
PORT_IDENTITY_TCP=4002
HOST_IDENTITY_TCP=localhost

# AI enrichment configuration
AI_PAGE_MAX_CHARS=4000
AI_ENRICHMENT_ENABLED=false
AI_PAGE_FETCH_TIMEOUT_MS=10000

# Gemini API configuration
GEMINI_MODEL=gemini-3-flash
GEMINI_API_KEY=your_gemini_api_key

# Redis / BullMQ configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Identity database configuration
DB_IDENTITY_PORT=5433
DB_IDENTITY_HOST=localhost
DB_IDENTITY_NAME=identity_db
DB_IDENTITY_USER=identity_user
DB_IDENTITY_PASSWORD=identity_password

# Short URL database configuration
DB_SHORT_URL_PORT=5434
DB_SHORT_URL_HOST=localhost
DB_SHORT_URL_NAME=short_url_db
DB_SHORT_URL_USER=short_url_user
DB_SHORT_URL_PASSWORD=short_url_password
